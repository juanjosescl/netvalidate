# Copy this file to .env and adjust as needed.
# Never commit .env to git — only this template.

# ----------------------------------------------------------------------------
# API
# ----------------------------------------------------------------------------

# API key required in the X-API-Key header for protected endpoints.
NETVALIDATE_API_KEY=change-me-to-a-long-random-string

# Database URL (default: local SQLite under ./data/).
NETVALIDATE_DB_URL=sqlite+aiosqlite:///./data/netvalidate.db

# Directory where YAML validation profiles are loaded from.
NETVALIDATE_PROFILES_DIR=./examples/profiles

# Log level: DEBUG, INFO, WARNING, ERROR.
NETVALIDATE_LOG_LEVEL=INFO

# Per-job timeout in seconds.
NETVALIDATE_JOB_TIMEOUT_SECONDS=300


# ----------------------------------------------------------------------------
# Device credentials (optional)
# ----------------------------------------------------------------------------
# When NOT set, validators run with built-in mock data. This is intentional
# so the project is reproducible without real devices (e.g. for demos and CI).
#
# When set, collect() will SSH/telnet to actual devices.
# In a production deployment these values should come from a secrets manager
# or be referenced via `credentials_ref` in the validate request.

# Cisco IOS / IOS XE
# NETVALIDATE_CISCO_USERNAME=netadmin
# NETVALIDATE_CISCO_PASSWORD=change-me
# NETVALIDATE_CISCO_ENABLE=change-me


# ----------------------------------------------------------------------------
# Pivot host (optional)
# ----------------------------------------------------------------------------
# When a request includes `pivot_host`, the manager SSHes into the pivot,
# launches telnet to the device, then redispatches the Netmiko session.

# NETVALIDATE_PIVOT_PORT=22
# NETVALIDATE_PIVOT_USERNAME=jumpuser
# NETVALIDATE_PIVOT_PASSWORD=change-me
